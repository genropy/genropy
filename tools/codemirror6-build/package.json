{
  "name": "genropy-codemirror6-build",
  "version": "1.0.0",
  "private": true,
  "description": "Build pipeline for the CodeMirror 6 bundle vendored into Genropy at genropy/resources/js_libs/codemirror6/.",
  "scripts": {
    "build": "esbuild entry.js --bundle --minify --format=iife --target=es2020 --sourcemap=external --outfile=../../resources/js_libs/codemirror6/codemirror6.bundle.js"
  },
  "dependencies": {
    "@codemirror/commands": "^6.6.0",
    "@codemirror/lang-css": "^6.2.1",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.1.6",
    "@codemirror/lang-sql": "^6.7.1",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.10.2",
    "@codemirror/search": "^6.5.6",
    "@codemirror/state": "^6.4.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.28.4",
    "thememirror": "^2.0.1"
  },
  "devDependencies": {
    "esbuild": "^0.23.0"
  }
}
