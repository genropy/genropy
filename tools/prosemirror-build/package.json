{
  "name": "genropy-prosemirror-build",
  "version": "1.0.0",
  "private": true,
  "description": "Build pipeline for the ProseMirror bundle vendored into Genropy at genropy/resources/js_libs/prosemirror/.",
  "scripts": {
    "build": "esbuild entry.js --bundle --minify --format=iife --target=es2020 --sourcemap=external --outfile=../../resources/js_libs/prosemirror/prosemirror.bundle.js"
  },
  "dependencies": {
    "prosemirror-state": "^1.4.3",
    "prosemirror-view": "^1.34.3",
    "prosemirror-model": "^1.23.0",
    "prosemirror-transform": "^1.10.2",
    "prosemirror-commands": "^1.6.0",
    "prosemirror-keymap": "^1.2.2",
    "prosemirror-history": "^1.4.1",
    "prosemirror-inputrules": "^1.4.0",
    "prosemirror-schema-basic": "^1.2.3",
    "prosemirror-schema-list": "^1.4.1",
    "prosemirror-dropcursor": "^1.8.1",
    "prosemirror-gapcursor": "^1.3.2",
    "prosemirror-menu": "^1.2.4",
    "prosemirror-example-setup": "^1.2.3",
    "prosemirror-tables": "^1.6.1",
    "prosemirror-trailing-node": "^3.0.0",
    "prosemirror-collab": "^1.3.1",
    "prosemirror-changeset": "^2.4.1"
  },
  "devDependencies": {
    "esbuild": "^0.23.0"
  }
}
