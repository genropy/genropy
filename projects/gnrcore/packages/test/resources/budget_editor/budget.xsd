<?xml version="1.0" encoding="UTF-8"?>
<!--
  Quick Budget Editor — XML Schema (XSD 1.0).

  Validates files produced by the budget editor demo page
  (`editor_budget.py`, save round-trip via `Bag.toXml(pretty=True)`).
  Three nesting levels: chapters → accounts → details.

  ===========================================================================
  Genropy Bag XML conventions honoured by this schema
  ===========================================================================

  - Root element is <GenRoBag>.
  - A "list" in the Bag (chapters, accounts, details) is serialised as a
    container element whose children are the list items. Item element
    names are generated by Bag.toXml as `r_NNN` (zero-padded, sequential)
    but XSD 1.0 cannot enforce that pattern declaratively, so we accept
    any element name for list items (`xs:any processContents="lax"`).
    Item ORDER on disk is the iteration order — preserve it on save.
  - Every leaf element MAY carry a `_T` attribute that declares its
    Genropy dtype. When the element contains a typed value, `_T` is
    required by Bag's own loader; when the element is plain text (the
    default text dtype `T`) the attribute is omitted. Allowed `_T`
    values used by the budget data: `D` date (ISO 8601),
    `L` integer (Python int), `N` numeric (float/Decimal), `NN`
    "numeric null" (empty payload), `B` boolean (`true`/`false`).
  - Typed leaves MAY be empty (e.g. `<n_ris _T="NN"></n_ris>` means
    "no value"). The schema accepts empty content on all typed leaves.

  ===========================================================================
  Domain rules expressed by this schema
  ===========================================================================

  Chapter / Account / Detail records all carry their own `codice` and
  `descr`. Details additionally carry the spreadsheet columns whose
  enumerations track the page's filteringSelect `values=` declarations
  (kept in sync with `conto_card.py`).
-->
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           elementFormDefault="qualified"
           attributeFormDefault="unqualified">

  <!-- ===================================================================
       Reusable building blocks
       =================================================================== -->

  <!--
    `_T` attribute — Genropy dtype marker. Optional on every leaf.
    Limited to the values that actually appear in budget files; extend
    the enumeration if you introduce new dtypes (e.g. `B` for booleans,
    `A` for bag attachments).
  -->
  <xs:simpleType name="GnrTypeAttr">
    <xs:restriction base="xs:string">
      <xs:enumeration value="T"/>
      <xs:enumeration value="L"/>
      <xs:enumeration value="N"/>
      <xs:enumeration value="NN"/>
      <xs:enumeration value="D"/>
      <xs:enumeration value="B"/>
    </xs:restriction>
  </xs:simpleType>

  <!--
    A "typed leaf" — element whose body may be empty (typed-null) and
    whose `_T` attribute, if present, declares the dtype. Used as the
    base for date/integer/numeric leaves below.
  -->
  <xs:complexType name="TypedLeaf">
    <xs:simpleContent>
      <xs:extension base="xs:string">
        <xs:attribute name="_T" type="GnrTypeAttr" use="optional"/>
      </xs:extension>
    </xs:simpleContent>
  </xs:complexType>

  <!--
    Closed enumerations for detail columns. The values mirror the
    `filteringSelect` declarations in `conto_card.py` — keep in sync.
    Empty content is accepted (user has not picked a value yet).
  -->
  <xs:simpleType name="TipoEnum">
    <xs:restriction base="xs:string">
      <xs:enumeration value=""/>
      <xs:enumeration value="ACQ"/>
      <xs:enumeration value="CMP"/>
      <xs:enumeration value="RIS"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="FaseEnum">
    <xs:restriction base="xs:string">
      <xs:enumeration value=""/>
      <xs:enumeration value="Preparazione"/>
      <xs:enumeration value="Riprese"/>
      <xs:enumeration value="Post"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="DistribEnum">
    <xs:restriction base="xs:string">
      <xs:enumeration value=""/>
      <xs:enumeration value="UNI"/>
      <xs:enumeration value="FL"/>
      <xs:enumeration value="QT"/>
    </xs:restriction>
  </xs:simpleType>

  <!--
    Percentage-style enumerations (IVA, Al.Oneri, Al.Rit.). The values
    come from the filteringSelect declarations and represent integer
    percent points stored as `_T="L"` integers.
  -->
  <xs:simpleType name="IvaEnum">
    <xs:restriction base="xs:string">
      <xs:enumeration value=""/>
      <xs:enumeration value="0"/>
      <xs:enumeration value="10"/>
      <xs:enumeration value="22"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="OneriEnum">
    <xs:restriction base="xs:string">
      <xs:enumeration value=""/>
      <xs:enumeration value="0"/>
      <xs:enumeration value="30"/>
      <xs:enumeration value="33"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="RitEnum">
    <xs:restriction base="xs:string">
      <xs:enumeration value=""/>
      <xs:enumeration value="0"/>
      <xs:enumeration value="20"/>
      <xs:enumeration value="23"/>
    </xs:restriction>
  </xs:simpleType>

  <!-- Helper: an enumerated leaf carries `_T="L"` when the value is an
       integer percent (IVA / Al.Oneri / Al.Rit.). -->
  <xs:complexType name="EnumLeafL">
    <xs:simpleContent>
      <xs:extension base="IvaEnum">
        <xs:attribute name="_T" type="GnrTypeAttr" use="optional"/>
      </xs:extension>
    </xs:simpleContent>
  </xs:complexType>

  <xs:complexType name="EnumLeafOneri">
    <xs:simpleContent>
      <xs:extension base="OneriEnum">
        <xs:attribute name="_T" type="GnrTypeAttr" use="optional"/>
      </xs:extension>
    </xs:simpleContent>
  </xs:complexType>

  <xs:complexType name="EnumLeafRit">
    <xs:simpleContent>
      <xs:extension base="RitEnum">
        <xs:attribute name="_T" type="GnrTypeAttr" use="optional"/>
      </xs:extension>
    </xs:simpleContent>
  </xs:complexType>

  <!-- ===================================================================
       Detail record (innermost: one spreadsheet row)
       =================================================================== -->

  <xs:complexType name="DetailRecord">
    <xs:all>
      <xs:element name="tipo"        type="TipoEnum"        minOccurs="0"/>
      <xs:element name="descrizione" type="xs:string"       minOccurs="0"/>
      <xs:element name="fase"        type="FaseEnum"        minOccurs="0"/>
      <xs:element name="data_rif"    type="TypedLeaf"       minOccurs="0"/>
      <xs:element name="n_ris"       type="TypedLeaf"       minOccurs="0"/>
      <xs:element name="qty"         type="TypedLeaf"       minOccurs="0"/>
      <xs:element name="p_u"         type="TypedLeaf"       minOccurs="0"/>
      <xs:element name="iva"         type="EnumLeafL"       minOccurs="0"/>
      <xs:element name="al_oneri"    type="EnumLeafOneri"   minOccurs="0"/>
      <xs:element name="al_rit"      type="EnumLeafRit"     minOccurs="0"/>
      <xs:element name="distrib"     type="DistribEnum"     minOccurs="0"/>
      <!-- Derived total (computed client-side via `formula=`). Tolerated
           on input so a round-tripped file validates without manual
           stripping. -->
      <xs:element name="tot_netto"   type="TypedLeaf"       minOccurs="0"/>
    </xs:all>
  </xs:complexType>

  <!-- ===================================================================
       Account record (one row inside a chapter)
       =================================================================== -->

  <xs:complexType name="AccountRecord">
    <xs:all>
      <xs:element name="codice"  type="xs:string" minOccurs="0"/>
      <xs:element name="descr"   type="xs:string" minOccurs="0"/>
      <xs:element name="details" type="DetailsList" minOccurs="0"/>
      <!-- Account total — derived client-side via dataFormula, may
           appear in round-tripped files. -->
      <xs:element name="tot_conto" type="TypedLeaf" minOccurs="0"/>
    </xs:all>
  </xs:complexType>

  <xs:complexType name="DetailsList">
    <!-- Children are detail records named `r_NNN`. XSD 1.0 cannot
         pattern-match element names declaratively, so we accept any
         element and bind each to DetailRecord at validation time
         via `xs:any processContents="lax"` + a single child group.
         For practical use: any list-item element will validate
         against `DetailRecord` if a same-named global element of that
         type exists. We declare it under the global namespace below. -->
    <xs:sequence>
      <xs:any namespace="##local"
              processContents="lax"
              minOccurs="0"
              maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <!-- ===================================================================
       Chapter record (one tab in the editor)
       =================================================================== -->

  <xs:complexType name="ChapterRecord">
    <xs:all>
      <xs:element name="codice"   type="xs:string" minOccurs="0"/>
      <xs:element name="descr"    type="xs:string" minOccurs="0"/>
      <xs:element name="accounts" type="AccountsList" minOccurs="0"/>
      <!-- Chapter total — derived client-side, tolerated on round-trip. -->
      <xs:element name="tot_capitolo" type="TypedLeaf" minOccurs="0"/>
    </xs:all>
  </xs:complexType>

  <xs:complexType name="AccountsList">
    <xs:sequence>
      <xs:any namespace="##local"
              processContents="lax"
              minOccurs="0"
              maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <!-- ===================================================================
       Root: <GenRoBag> containing the chapters list
       =================================================================== -->

  <xs:complexType name="ChaptersRoot">
    <xs:sequence>
      <xs:any namespace="##local"
              processContents="lax"
              minOccurs="0"
              maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:element name="GenRoBag" type="ChaptersRoot"/>

</xs:schema>
